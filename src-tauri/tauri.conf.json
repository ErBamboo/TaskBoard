{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Robot Task Board",
  "version": "0.1.0",
  "identifier": "lab.ohmyrobot.taskboard",
  "build": {
    "frontendDist": "./desktop-shell",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
