# Public Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Public anonymous key used by the browser and SSR session reads
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fixed remote app URL loaded by the Windows desktop shell during desktop builds
NEXT_PUBLIC_DESKTOP_APP_URL=

# Server-only service role key used by admin account operations
SUPABASE_SERVICE_ROLE_KEY=
